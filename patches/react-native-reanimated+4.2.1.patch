@@ -0,0 +1,36 @@
+'use strict';
+
+import { useCallback, useEffect, useRef } from 'react';
+import type { DependencyList } from './commonTypes';
+import { runOnJS } from '../workletFunctions';
+
+/**
+ * Compatibility shim for Reanimated 4: useWorkletCallback was removed.
+ * Returns a worklet that invokes the latest callback via runOnJS so it runs on the JS thread.
+ * @deprecated Prefer using callbacks that don't require worklet context, or use react-native-worklets directly.
+ */
+export function useWorkletCallback<T extends (...args: any[]) => void>(
+  callback: T,
+  dependencies?: DependencyList
+): T {
+  const ref = useRef(callback);
+  useEffect(() => {
+    ref.current = callback;
+  }, dependencies ?? [callback]);
+
+  const callRef = useCallback((...args: any[]) => {
+    return ref.current(...args);
+  }, []);
+
+  const worklet = useCallback(
+    (...args: any[]) => {
+      'worklet';
+      (runOnJS as (fn: (...a: any[]) => void) => (...a: any[]) => void)(
+        callRef
+      )(...args);
+    },
+    [callRef]
+  ) as T;
+
+  return worklet;
+}
